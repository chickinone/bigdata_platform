        "silver:enriched_transactions.transaction_id"
      ]
    },
    {
      "engine": "spark",
      "pipeline": "gold_customer_lifetime_metrics",
      "output": "gold:customer_lifetime_metrics.lifetime_value",
      "expr": "SUM(CAST(amount AS DOUBLE)) AS lifetime_value",
