  "column_lineage": [
    {
      "pipeline": "metric_breakdown",
      "output": "bank.metric.breakdown.tx_type",
      "expr": "`after`.transaction_type",
      "inputs": [
        "bank.public.transactions.transaction_type"
      ]
    },
    {
      "pipeline": "metric_breakdown",
      "output": "bank.metric.breakdown.tx_count",
      "expr": "COUNT(*)",
      "inputs": []
    },
    {
      "pipeline": "metric_breakdown",
      "output": "bank.metric.breakdown.total_value",
      "expr": "SUM(CAST(`after`.amount AS DECIMAL(19, 4)))",
      "inputs": [
        "bank.public.transactions.amount"
      ]
    },
    {
      "pipeline": "metric_breakdown",
      "output": "bank.metric.breakdown.success_count",
      "expr": "COUNT(*) FILTER (WHERE `after`.status = 'completed')",
      "inputs": [
        "bank.public.transactions.status"
      ]
    },
    {
      "pipeline": "metric_breakdown",
      "output": "bank.metric.breakdown.failed_count",
      "expr": "COUNT(*) FILTER (WHERE `after`.status = 'failed')",
      "inputs": [
        "bank.public.transactions.status"
      ]
    },
    {
      "pipeline": "metric_kpi",
      "output": "bank.metric.kpi.total_count",
      "expr": "COUNT(*)",
      "inputs": []
    },
    {
      "pipeline": "metric_kpi",
      "output": "bank.metric.kpi.total_value",
      "expr": "SUM(CAST(`after`.amount AS DECIMAL(19, 4)))",
      "inputs": [
        "bank.public.transactions.amount"
      ]
    },
    {
      "pipeline": "metric_kpi",
      "output": "bank.metric.kpi.success_count",
      "expr": "COUNT(*) FILTER (WHERE `after`.status = 'completed')",
      "inputs": [
        "bank.public.transactions.status"
      ]
    },
    {
      "pipeline": "metric_kpi",
      "output": "bank.metric.kpi.failed_count",
      "expr": "COUNT(*) FILTER (WHERE `after`.status = 'failed')",
      "inputs": [
        "bank.public.transactions.status"
      ]
    },
    {
      "pipeline": "metric_kpi",
      "output": "bank.metric.kpi.success_rate",
      "expr": "CAST(COUNT(*) FILTER (WHERE `after`.status = 'completed') * 100.0 / NULLIF(COUNT(*), 0) AS DECIMAL(5, 2))",
      "inputs": [
        "bank.public.transactions.status"
      ]
    },
    {
      "pipeline": "metric_kpi",
      "output": "bank.metric.kpi.active_users",
      "expr": "COUNT(DISTINCT `after`.account_id)",
      "inputs": [
        "bank.public.transactions.account_id"
      ]
    },
    {
      "pipeline": "metric_timeseries",
      "output": "bank.metric.timeseries.tx_type",
      "expr": "`after`.transaction_type",
      "inputs": [
        "bank.public.transactions.transaction_type"
      ]
    },
    {
      "pipeline": "metric_timeseries",
      "output": "bank.metric.timeseries.tx_count",
      "expr": "COUNT(*)",
      "inputs": []
    },
    {
      "pipeline": "metric_timeseries",
      "output": "bank.metric.timeseries.total_amount",
      "expr": "SUM(CAST(`after`.amount AS DECIMAL(19, 4)))",
      "inputs": [
        "bank.public.transactions.amount"
      ]
    },
    {
      "pipeline": "metric_topn",
      "output": "bank.metric.topn.account_id",
      "expr": "`after`.account_id",
      "inputs": [
        "bank.public.transactions.account_id"
      ]
    },
    {
      "pipeline": "metric_topn",
      "output": "bank.metric.topn.tx_count",
      "expr": "COUNT(*)",
      "inputs": []
    },
    {
      "pipeline": "metric_topn",
      "output": "bank.metric.topn.total_value",
      "expr": "SUM(CAST(`after`.amount AS DECIMAL(19, 4)))",
      "inputs": [
        "bank.public.transactions.amount"
      ]
    }
  ]
}
