connector.name=iceberg
iceberg.catalog.type=hadoop
iceberg.catalog.warehouse=${ENV:ICEBERG_WAREHOUSE}/
hive.s3.endpoint=${ENV:S3_ENDPOINT}
hive.s3.path-style-access=${ENV:S3_PATH_STYLE_ACCESS}
hive.s3.aws-access-key=${ENV:S3_ACCESS_KEY}
hive.s3.aws-secret-key=${ENV:S3_SECRET_KEY}
hive.s3.ssl.enabled=${ENV:S3_SSL_ENABLED}
