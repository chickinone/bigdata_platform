# Mẫu biến môi trường — copy sang `.env` và điền giá trị thật. KHÔNG commit `.env`.
# Mọi secret ở đây là placeholder; artifact sinh chỉ tham chiếu ${ENV:...}, không chứa giá trị thật.

# --- PostgreSQL (OLTP nguồn) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bankdb
POSTGRES_USER=admin
POSTGRES_PASSWORD=<your_postgres_password>

# --- Debezium replication role ---
REPLICATION_USER=replicator
REPLICATION_PASSWORD=<your_replication_password>

# --- Application generator role ---
APP_USER=bankapp
APP_PASSWORD=<your_app_password>

# --- ClickHouse ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=<your_clickhouse_password>

# --- Kafka / Schema Registry ---
KAFKA_BOOTSTRAP=kafka:9092
SCHEMA_REGISTRY_URL=http://schema-registry:8081
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- MinIO / S3 (lakehouse) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<your_minio_password>
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=<your_s3_access_key>
S3_SECRET_KEY=<your_s3_secret_key>
S3_PATH_STYLE_ACCESS=true
S3_SSL_ENABLED=false
S3_BUCKET_BRONZE=data-lake-bronze

# --- Iceberg REST catalog ---
ICEBERG_REST_URI=http://iceberg-rest:8181
ICEBERG_WAREHOUSE=s3a://data-lake-iceberg/warehouse
ICEBERG_CATALOG_WAREHOUSE=s3://data-lake-iceberg/

# --- Fraud notifier email (tuỳ chọn) ---
EMAIL_FROM=<your_email@gmail.com>
EMAIL_TO=<receiver_email@gmail.com>
EMAIL_PASSWORD=<gmail_app_password>
